<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- application-{profile}.yml 에서 주입 -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="allreva"/>
    <springProperty scope="context" name="LOKI_URL" source="loki.url" defaultValue=""/>

    <!-- ==================== Console Appender ==================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{36}) [%X{traceId}:%X{spanId}] - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== File Appender (dev only) ==================== -->
    <springProfile name="dev">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/application.log</file>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{traceId}:%X{spanId}] - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/application-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>30</maxHistory>
            </rollingPolicy>
        </appender>
    </springProfile>

    <!-- ==================== Loki Appender (dev, stag, prod) ==================== -->
    <springProfile name="dev,stag,prod">
        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <http>
                <url>${LOKI_URL}</url>
            </http>
            <format>
                <label>
                    <pattern>app=${APP_NAME},env=${spring.profiles.active:dev},level=%level</pattern>
                </label>
                <message>
                    <pattern>
                        {
                          "timestamp": "%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}",
                          "level": "%level",
                          "thread": "%thread",
                          "logger": "%logger{36}",
                          "traceId": "%X{traceId:-}",
                          "spanId": "%X{spanId:-}",
                          "message": "%message",
                          "exception": "%ex{10}"
                        }
                    </pattern>
                </message>
                <sortByTime>true</sortByTime>
            </format>
        </appender>

        <appender name="ASYNC_LOKI" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="LOKI"/>
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
        </appender>
    </springProfile>

    <!-- ==================== Root Logger ==================== -->
    <root level="INFO">
        <springProfile name="test,dev,stag,prod">
            <appender-ref ref="CONSOLE"/>
        </springProfile>
        <springProfile name="dev">
            <appender-ref ref="FILE"/>
        </springProfile>
        <springProfile name="dev,stag,prod">
            <appender-ref ref="ASYNC_LOKI"/>
        </springProfile>
    </root>

    <!-- ==================== Application Logger ==================== -->
    <logger name="com.backend.allreva" level="INFO" additivity="false">
        <springProfile name="test,dev,stag,prod">
            <appender-ref ref="CONSOLE"/>
        </springProfile>
        <springProfile name="dev">
            <appender-ref ref="FILE"/>
        </springProfile>
        <springProfile name="dev,stag,prod">
            <appender-ref ref="ASYNC_LOKI"/>
        </springProfile>
    </logger>
</configuration>

